{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --env-file=.env --watch server/index.js",
    "start:api:prod": "node server/index.js",
    "start:api": "node --env-file=.env server/index.js",
    "backup:db": "node --env-file=.env server/backup.js",
    "healthcheck:api": "node --env-file=.env server/healthcheck.js",
    "pg:migrate:core": "node --env-file=.env server/scripts/migrate-sqlite-to-postgres.mjs", 
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "node --test tests/api/**/*.test.mjs",
    "test:e2e": "playwright test",
    "build:release": "npm run typecheck && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.99.2",
    "@types/leaflet": "^1.9.21",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "pg": "^8.13.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.2",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
